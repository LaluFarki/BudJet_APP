# Auto-detect text files and normalize line endings to LF on commit
* text=auto

# Dart, YAML, and configuration files should always use LF line endings
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.plist text eol=lf
*.xcconfig text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.cmake text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.swift text eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Windows batch files must always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (images, assets) should not be touched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.zip binary
